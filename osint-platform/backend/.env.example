# --- Application ---
APP_NAME="OSINT Platform"
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# --- Database ---
# Default uses SQLite (file lives in ./data/osint.db). Switch to PostgreSQL in production.
DATABASE_URL=sqlite+aiosqlite:///./data/osint.db
# DATABASE_URL=postgresql+psycopg2://osint:osint@db:5432/osint

# --- Crawling ---
USER_AGENT="OSINT-Platform/1.0 (+https://example.com/bot)"
REQUEST_TIMEOUT=10
MAX_CRAWL_DEPTH=1
MAX_PAGES_PER_SEARCH=15
RATE_LIMIT_PER_MINUTE=30
RESPECT_ROBOTS_TXT=true

# --- Optional: Public search APIs ---
# These are OPTIONAL. The platform works without them by generating shareable
# search URLs (Google dorks etc). If you have keys to legal/public APIs, set
# them here.
SERPAPI_KEY=
HIBP_API_KEY=

# --- Elasticsearch (internal intelligence layer) ---
# Set ES_ENABLED=true to query a local Elasticsearch index (`tc_index`) as an
# extra enrichment layer alongside the existing OSINT pipeline. Disabled by
# default — leaving these blank keeps the platform running on pure OSINT.
ES_ENABLED=false
ES_URL=https://localhost:9200
ES_USER=elastic
ES_PASSWORD=
ES_INDEX=tc_index
ES_VERIFY_CERTS=false
ES_CA_CERT=
ES_TIMEOUT=8
ES_MAX_HITS=25

# --- Security ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000